{
    "name": "codepower/sms-mitake",
    "description": "A PHP client for the Mitake (三竹簡訊) SMS HTTP API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["sms", "mitake", "三竹", "簡訊", "taiwan"],
    "authors": [
        {
            "name": "Gasol Wu",
            "email": "gasol.wu+github@gmail.com",
            "role": "developer"
        }
    ],
    "support": {
        "issues": "https://github.com/codepower-tw/sms-mitake-php/issues"
    },
    "require": {
        "php": ">=8.1",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "suggest": {
        "ext-mbstring": "Required to send messages using the Big5 charset."
    },
    "autoload": {
        "psr-4": {
            "CodePower\\Mitake\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodePower\\Mitake\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
